# Copy this file to .env.local and fill in real values.
# See docs/operations.md §4 for where to find each value.

# Supabase — public, but production values matter
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Used by /api/auth to build magic-link redirect URLs.
# Local: http://localhost:3000
# Production: https://veloadout.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Anthropic API key. Sourced from console.anthropic.com.
# Note: historical name — not ANTHROPIC_API_KEY.
VELOADOUT_API_KEY=sk-ant-...

# Upstash Redis (for distributed rate limit + daily AI budget).
# Without these, rate limiting falls back to in-memory per-instance.
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=...
